# ──────────────────────────────────────────
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# Groq Cloud API key (required — get one at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini API key (optional — only needed if USE_GEMINI=true)
GEMINI_API_KEY=

# LinkedIn credentials
LINKEDIN_EMAIL=your_email@gmail.com
LINKEDIN_PASSWORD=your_password_here

# Scoring threshold (0.0 – 1.0). Jobs below this score are skipped.
SCORE_THRESHOLD=0.65

# Paths
DB_PATH=data/jobs.db
PROFILE_PATH=profiles/user_profile.json
RESUME_PATH=C:\path\to\your\resume.pdf

# Google Sheets integration (optional — leave blank to skip)
SHEETS_ID=your_google_sheet_id_here

# Model selection: set to "true" to use Gemini as the primary LLM instead of Groq
USE_GEMINI=false
